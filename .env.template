# ============================================================
# InstaAgent — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Meta / Instagram ─────────────────────────────────────────
# Long-lived access token from Meta Developer Console
META_ACCESS_TOKEN=your_meta_long_lived_access_token_here

# Your Instagram Business/Creator Account ID (numeric)
IG_ACCOUNT_ID=your_instagram_account_id_here

# ── Unsplash ─────────────────────────────────────────────────
# Access Key from https://unsplash.com/developers (free tier = 50 req/hr)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# ── Ollama ───────────────────────────────────────────────────
# Ollama server URL (default — change if running on different port)
OLLAMA_BASE_URL=http://localhost:11434

# ── Ngrok Tunnel ────────────────────────────────────────────────────────────
# Optional but recommended: ngrok auth token for stable, secure public tunnels.
# Bypasses local network restrictions (CGNAT) and avoids manual port forwarding.
# Get a free token at https://dashboard.ngrok.com
NGROK_AUTH_TOKEN=

# ── ImgBB Upload ────────────────────────────────────────────────────────────
# Optional alternative to Ngrok. Uploads images temporarily to ImgBB.
# Get a free API key at https://api.imgbb.com/
IMGBB_API_KEY=

# ── Competitor / Repost Scraping (OPTIONAL) ───────────────────────────────────
# A secondary/burner IG account for read-only scraping.
# Do NOT use your main account here.
#
# RECOMMENDED: Use IG_SESSION_ID (browser cookie) to bypass IP blacklisting.
# How to get it: Log into your burner account in Chrome/Firefox
#   F12 > Application > Cookies > https://www.instagram.com > copy "sessionid" value
IG_SESSION_ID=

# Fallback: username + password (may be blocked on new IPs)
IG_SCRAPE_USER=
IG_SCRAPE_PASS=
